# Local desktop-build secrets — copy to .env (gitignored) and fill in.
# Signing alone needs none of these (the Makefile finds the Developer ID
# certificate in the login keychain); these enable notarization.
#
# APPLE_PASSWORD is an app-specific password from appleid.apple.com
# (Sign-In and Security -> App-Specific Passwords), NOT your Apple ID password.
APPLE_ID=you@example.com
APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=S4XLTSHM8N
